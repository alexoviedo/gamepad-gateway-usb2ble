{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "types": []
  },
  "include": ["webapp/**/*.js"]
}
